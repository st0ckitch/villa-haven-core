# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example`.

# Supabase — required (read values from Supabase project dashboard)
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Bitrix24 CRM — optional, see BITRIX_SETUP.md for how to get this URL.
# When set, every contact form submission ALSO creates a Lead in Bitrix24.
# Format: https://<company>.bitrix24.com/rest/1/<token>/
# Leave blank to disable the Bitrix integration (forms still save to Supabase).
VITE_CRM_WEBHOOK_URL=
